# Copy this file to .env and fill in the values before starting.
# Never commit .env to version control.

# PostgreSQL (used by the db service in docker-compose)
POSTGRES_USER=rentflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=rentflow

# Prisma connection string.
# Docker Compose: host is 'db' (the service name).
# Local dev outside Docker: use 'localhost'.
DATABASE_URL=postgresql://rentflow:change_me@db:5432/rentflow

# JSON Web Token secret — use a long, random string in production.
JWT_SECRET=change_me_to_a_long_random_secret
