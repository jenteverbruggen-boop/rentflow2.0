# Copy this file to .env and fill in the values before starting.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=rentflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=rentflow

# Prisma connection string — must match the credentials above.
# When running via Docker Compose the host is 'db' (the service name).
# For local development outside Docker use 'localhost'.
DATABASE_URL=postgresql://rentflow:change_me@db:5432/rentflow

# JSON Web Token secret — use a long, random string in production.
JWT_SECRET=change_me_to_a_long_random_secret

# Allowed CORS origin for the backend.
# Set to the URL where the frontend is served.
FRONTEND_URL=http://localhost:3000
